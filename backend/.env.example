# Backend runtime
PORT=4000
NODE_ENV=development

# Security
AUTH_SECRET=replace_with_a_random_64_char_secret
AUTH_TOKEN_TTL_MS=86400000
ENFORCE_HTTPS=false
CORS_ORIGIN=http://localhost:5173

# AI Provider Selection: groq | bedrock
AI_PROVIDER=groq
AI_MODEL=
AI_TIMEOUT_MS=30000

# Groq (if AI_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=30000

# AWS Bedrock (if AI_PROVIDER=bedrock)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=

# Google Sign-In verification (optional but recommended if using Google auth)
GOOGLE_CLIENT_ID=

# AWS Polly voice synthesis (optional overrides)
AWS_POLLY_VOICE_ID=
AWS_POLLY_LANGUAGE_CODE=
AWS_POLLY_ENGINE=neural
